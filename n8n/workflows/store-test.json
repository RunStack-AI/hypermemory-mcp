        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"jsonrpc\": \"2.0\",\n  \"id\": {{ $now.toMillis() }},\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"memory_recall\",\n    \"arguments\": {\n      \"query\": \"test from n8n\"\n    }\n  }\n}",
        "options": {}
      },
      "id": "recall",
      "name": "Recall Memory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [650, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "HyperMemory API"
        }
      }
    }
