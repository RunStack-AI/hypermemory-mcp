        "specifyBody": "json",
        "jsonBody": "={\n  \"jsonrpc\": \"2.0\",\n  \"id\": {{ $now.toMillis() }},\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"memory_store\",\n    \"arguments\": {\n      \"key\": \"test_from_n8n\",\n      \"description\": \"This is a test memory created from n8n at {{ $now.toISO() }}\"\n    }\n  }\n}",
        "options": {}
      },
      "id": "store",
      "name": "Store Memory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_CREDENTIAL_ID",
          "name": "HyperMemory API"
        }
      }
    },
    {
      "parameters": {
